generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  password         String
  phone            String?
  tag              String?         @unique
  firstName        String?
  lastName         String?
  kycStatus        String?         @default("NOT_SUBMITTED")
  referralCode     String?         @unique
  referredById     String?
  biometricEnabled Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  socType          String?
  beneficiaries    Beneficiary[]
  cryptoAddress    CryptoAddress[]
  cryptoDeposit    CryptoDeposit[]
  paymentLinks     PaymentLink[]
  transactions     Transaction[]   @relation("UserTransactions")
  referredBy       User?           @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]          @relation("Referrals")
  security         UserSecurity?
  wallets          Wallet[]
  sentReferrals    Referral[] @relation("ReferralInviter")
  receivedReferral Referral[] @relation("ReferralInvitee")
}

model Wallet {
  id                   Int           @id @default(autoincrement())
  userId               String
  balance              BigInt        @default(0)
  currency             String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @default(now()) @updatedAt
  sentTransactions     Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
  user                 User          @relation(fields: [userId], references: [id])

  @@unique([userId, currency])
}

model CryptoAddress {
  id        String   @id @default(cuid())
  userId    String
  currency  String
  address   String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model CryptoDeposit {
  id        String   @id @default(cuid())
  userId    String
  txHash    String   @unique
  address   String
  currency  String
  amount    BigInt
  ngnAmount BigInt
  fee       BigInt
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id           Int             @id @default(autoincrement())
  userId       String
  fromWalletId Int
  toWalletId   Int
  type         TransactionType
  amount       BigInt
  currency     String
  description  String?
  status       String          @default("PENDING")
  createdAt    DateTime        @default(now())
  fromWallet   Wallet          @relation("SentTransactions", fields: [fromWalletId], references: [id])
  toWallet     Wallet          @relation("ReceivedTransactions", fields: [toWalletId], references: [id])
  user         User            @relation("UserTransactions", fields: [userId], references: [id])
}

model Referral {
  id        String   @id @default(uuid())
  code      String   @unique
  inviterId String
  inviteeId String?
  reward    BigInt   @default(0)
  createdAt DateTime @default(now())

  inviter   User     @relation("ReferralInviter", fields: [inviterId], references: [id])
  invitee   User?    @relation("ReferralInvitee", fields: [inviteeId], references: [id])
}

model UserSecurity {
  id        String   @id @default(uuid())
  userId    String   @unique
  pinHash   String?
  twoFA     Boolean  @default(false)
  createdAt DateTime @default(now())
  biometric String?
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Beneficiary {
  id        String   @id @default(cuid())
  userId    String
  name      String
  tag       String
  accountNo String?
  bankName  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  type      String
  code      String
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, type], name: "email_type")
  @@index([expiresAt])
  @@map("otps")
}

model PaymentLink {
  id         Int      @id @default(autoincrement())
  userId     String
  amount     BigInt?
  openAmount Boolean  @default(false)
  code       String   @unique
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}



enum TransactionType {
  DEPOSIT
  WITHDRAW
  SEND
  RECEIVE
  REQUEST
}
