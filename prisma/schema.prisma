generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  password         String
  phone            String?
  tag              String?         @unique
  firstName        String?
  lastName         String?
  kycStatus        String?         @default("NOT_SUBMITTED")
  age              Int?
  referralCode     String?         @unique
  referredById     String?
  biometricEnabled Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  socType          String?
  beneficiaries    Beneficiary[]
  cryptoAddress    CryptoAddress[]
  cryptoDeposit    CryptoDeposit[]
  paymentLinks     PaymentLink[]
  transactions     Transaction[]   @relation("UserTransactions")
  referredBy       User?           @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]          @relation("Referrals")
  security         UserSecurity?
  wallets          Wallet[]
  sentReferrals    Referral[] @relation("ReferralInviter")
  receivedReferral Referral[] @relation("ReferralInvitee")
  transferRequests TransferRequest[]
}

model Wallet {
  id            String  @id @default(cuid())
  userId        String
  cryptocurrency String // BTC, ETH, USDT, USDC, SOL, BNB, SUI, APT
  address       String
  privateKey    String // Encrypted
  publicKey     String
  balance       Decimal @default(0) @db.Decimal(20, 8)
  nairaBalance  Decimal @default(0) @db.Decimal(15, 2)
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  sentTransactions     Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
  
  @@map("wallets")
  @@unique([userId, cryptocurrency])
}

model CryptoAddress {
  id        String   @id @default(cuid())
  userId    String
  chain     String
  currency  String
  address   String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model CryptoDeposit {
  id        String   @id @default(cuid())
  userId    String
  txHash    String   @unique
  address   String
  currency  String
  amount    BigInt
  ngnAmount BigInt
  fee       BigInt
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id           Int             @id @default(autoincrement())
  userId       String
  fromWalletId String?  // Changed to String and made optional
  toWalletId   String?  // Changed to String and made optional
  type         TransactionType
  amount       BigInt
  
  currency     String
  description  String?
  
  // Crypto-specific fields (from your payment engine requirements)
  cryptocurrency   String?
  cryptoAmount     Decimal?          @db.Decimal(20, 8)
  nairaAmount      Decimal           @db.Decimal(15, 2)
  exchangeRate     Decimal?          @db.Decimal(15, 8)
  status           TransactionStatus @default(PENDING)
  hash             String?           // Blockchain transaction hash
  fromAddress      String?
  toAddress        String?
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  fromWallet   Wallet?          @relation("SentTransactions", fields: [fromWalletId], references: [id])
  toWallet     Wallet?          @relation("ReceivedTransactions", fields: [toWalletId], references: [id])
  user         User            @relation("UserTransactions", fields: [userId], references: [id])
  
  @@map("transactions")
}

model Referral {
  id        String   @id @default(uuid())
  code      String   @unique
  inviterId String
  inviteeId String?
  reward    BigInt   @default(0)
  createdAt DateTime @default(now())

  inviter   User     @relation("ReferralInviter", fields: [inviterId], references: [id])
  invitee   User?    @relation("ReferralInvitee", fields: [inviteeId], references: [id])
}

model UserSecurity {
  id        String   @id @default(uuid())
  userId    String   @unique
  pinHash   String?
  twoFA     Boolean  @default(false)
  createdAt DateTime @default(now())
  biometric String?
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Beneficiary {
  id        String   @id @default(cuid())
  userId    String
  name      String
  tag       String
  accountNo String?
  bankName  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  type      String
  code      String
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, type], name: "email_type")
  @@index([expiresAt])
  @@map("otps")
}

model PaymentLink {
  id         Int      @id @default(autoincrement())
  userId     String
  title       String
  description String?
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("NGN")
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  openAmount Boolean  @default(false)
  code       String   @unique
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  
  @@map("payment_links")
}

model TransferRequest {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String?
  toEmail     String?
  toPhone     String?
  amount      Decimal  @db.Decimal(15, 2)
  message     String?
  status      String   @default("pending") // pending, completed, cancelled
  createdAt   DateTime @default(now())
  
  fromUser User @relation(fields: [fromUserId], references: [id])
  
  @@map("transfer_requests")
}

enum TransactionType {
  DEPOSIT
  CRYPTO_TO_NAIRA
  NAIRA_TO_CRYPTO
  WITHDRAW
  TRANSFER
  RECEIVE
  BILL_PAYMENT
  REQUEST
  PAYMENT_LINK
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}